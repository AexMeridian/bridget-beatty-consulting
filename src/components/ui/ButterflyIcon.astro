---
interface Props {
	class?: string;
	style?: string;
	static?: boolean;
}

const { class: className, style, static: isStatic = false } = Astro.props;
---

<svg
	class:list={['butterfly-icon', isStatic && 'is-static', className]}
	style={style}
	viewBox="0 0 48 64"
	width="32"
	height="43"
	fill="none"
	stroke="currentColor"
	stroke-width="1.7"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
>
	<path d="M24,16 C21,10 18,7 15,8" />
	<path d="M24,16 C27,10 30,7 33,8" />
	<line x1="24" y1="15" x2="24" y2="54" />
	<g class="wing wing-left">
		<path d="M24,20 C14,8 2,10 3,22 C4,32 16,32 24,26" />
		<path d="M24,30 C17,28 8,32 9,42 C10,50 18,50 24,40" />
	</g>
	<g class="wing wing-right">
		<path d="M24,20 C34,8 46,10 45,22 C44,32 32,32 24,26" />
		<path d="M24,30 C31,28 40,32 39,42 C38,50 30,50 24,40" />
	</g>
</svg>

<style>
	/*
	 * Ambient hero butterfly: absolutely positioned and drifts on a loop,
	 * using per-instance custom properties set inline by the caller
	 * (Hero.astro). Defined here (not in the caller) because Astro scopes
	 * each component's <style> block to elements it directly renders — a
	 * rule for this class written in the parent would never match this
	 * component's own root.
	 */
	.butterfly-icon {
		overflow: visible;
		position: absolute;
		top: var(--bfly-top, 20%);
		left: var(--bfly-left, 10%);
		width: var(--bfly-size, 32px);
		height: auto;
		translate: 0 0;
		opacity: 0;
		animation-name: butterfly-drift;
		animation-duration: var(--bfly-duration, 16s);
		animation-timing-function: ease-in-out;
		animation-iteration-count: infinite;
		animation-delay: var(--bfly-delay, 0s);
	}

	@keyframes butterfly-drift {
		0% {
			translate: 0 0;
			opacity: 0;
		}
		12% {
			opacity: var(--bfly-opacity, 0.4);
		}
		88% {
			opacity: var(--bfly-opacity, 0.4);
		}
		100% {
			translate: var(--bfly-dx, 120px) var(--bfly-dy, -80px);
			opacity: 0;
		}
	}

	/*
	 * Both wing groups scale horizontally toward the body line (x=24 in the
	 * viewBox) rather than toward their own centers, so shrinking reads as
	 * the wings folding in, not the whole shape squashing.
	 */
	.wing {
		transform-box: view-box;
		transform-origin: 24px 30px;
	}

	@keyframes wing-flap {
		0%,
		100% {
			transform: scaleX(1);
		}
		50% {
			transform: scaleX(0.32);
		}
	}

	.wing-left,
	.wing-right {
		animation: wing-flap 0.6s ease-in-out infinite;
	}

	.wing-right {
		animation-delay: 0.05s;
	}

	@media (prefers-reduced-motion: reduce) {
		.butterfly-icon {
			display: none;
		}
	}

	/* Quiet, motionless variant for use as a background watermark (e.g. footer). */
	.butterfly-icon.is-static {
		animation: none;
		opacity: var(--bfly-opacity, 0.08);
	}

	.butterfly-icon.is-static .wing-left,
	.butterfly-icon.is-static .wing-right {
		animation: none;
	}
</style>
