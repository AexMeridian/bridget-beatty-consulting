---
import { Image } from 'astro:assets';
import logo from '../../assets/brand/logo-lockup.png';
import Button from '../ui/Button.astro';
import { NAV_LINKS, CONTACT } from '../../data/site';
---

<header class="site-header" data-header>
	<div class="bar">
		<a href="/" class="logo-link" aria-label="Bridget Beatty Consulting, home">
			<Image src={logo} alt="Bridget Beatty Consulting — Helping organizations grow and evolve" width={880} height={222} widths={[520, 800]} sizes="520px" loading="eager" class="logo-img" />
		</a>

		<nav class="primary-nav" aria-label="Primary">
			<ul>
				{NAV_LINKS.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</nav>

		<div class="cta-desktop">
			<Button href={`mailto:${CONTACT.email}`} variant="solid-navy" ariaLabel={`Email Bridget Beatty at ${CONTACT.email}`}>Start a Conversation</Button>
		</div>

		<button
			type="button"
			class="nav-toggle"
			data-nav-toggle
			aria-expanded="false"
			aria-controls="mobile-nav-panel"
		>
			<span class="visually-hidden">Toggle menu</span>
			<span class="bars" aria-hidden="true">
				<span></span><span></span><span></span>
			</span>
		</button>
	</div>

	<div id="mobile-nav-panel" class="mobile-panel" data-nav-panel inert>
		<div class="mobile-panel-inner">
			<ul>
				{NAV_LINKS.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
			<div class="mobile-contact">
				<Button href={`mailto:${CONTACT.email}`} variant="solid-navy" ariaLabel={`Email Bridget Beatty at ${CONTACT.email}`}>Start a Conversation</Button>
			</div>
		</div>
	</div>
</header>

<script src="../../scripts/nav.js"></script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--color-paper);
		border-bottom: 1px solid var(--color-border);
		transition:
			box-shadow var(--transition-base),
			background-color var(--transition-base);
	}

	.site-header.is-scrolled {
		background: rgba(252, 250, 244, 0.92);
		backdrop-filter: blur(10px);
		box-shadow: var(--shadow-sm);
	}

	.bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-5);
		width: 100%;
		max-width: var(--max-width-wide);
		margin-inline: auto;
		padding-inline: clamp(1.25rem, 1rem + 1.5vw, 2.25rem);
		padding-block: 1rem;
	}

	.logo-link {
		position: relative;
		display: block;
		flex-shrink: 0;
		transition: transform var(--transition-base);
	}

	.logo-link:hover {
		transform: scale(1.03);
	}

	.logo-img {
		height: 132px;
		width: auto;
		transition: opacity 500ms ease;
	}

	.primary-nav {
		margin-inline-start: auto;
	}

	.primary-nav ul {
		display: flex;
		gap: var(--space-7);
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.primary-nav a {
		position: relative;
		color: var(--text-heading);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9375rem;
		padding-block: 0.35rem;
	}

	.primary-nav a::after {
		content: '';
		position: absolute;
		left: 0;
		right: 100%;
		bottom: 0;
		height: 2px;
		background: var(--color-teal);
		border-radius: 2px;
		transition: right var(--transition-base);
	}

	.primary-nav a:hover,
	.primary-nav a:focus-visible {
		color: var(--color-blue-dark);
	}

	.primary-nav a:hover::after,
	.primary-nav a:focus-visible::after {
		right: 0;
	}

	.nav-toggle {
		display: none;
		background: none;
		border: none;
		padding: var(--space-2);
		cursor: pointer;
	}

	.bars {
		display: flex;
		flex-direction: column;
		gap: 5px;
		width: 24px;
	}

	.bars span {
		display: block;
		height: 2px;
		background: var(--color-navy);
		border-radius: 2px;
		transition:
			transform var(--transition-base),
			opacity var(--transition-base);
		transform-origin: center;
	}

	.nav-toggle[aria-expanded='true'] .bars span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.nav-toggle[aria-expanded='true'] .bars span:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}

	.nav-toggle[aria-expanded='true'] .bars span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.mobile-panel {
		display: grid;
		grid-template-rows: 0fr;
		opacity: 0;
		transition:
			grid-template-rows var(--transition-base),
			opacity var(--transition-base);
	}

	.mobile-panel.is-open {
		grid-template-rows: 1fr;
		opacity: 1;
	}

	.mobile-panel > * {
		overflow: hidden;
		min-height: 0;
	}

	@media (max-width: 1240px) {
		.primary-nav,
		.cta-desktop {
			display: none;
		}

		.nav-toggle {
			display: inline-flex;
		}

		.mobile-panel {
			display: grid !important;
			border-top: 1px solid var(--color-border);
			background: var(--color-paper);
		}

		.mobile-panel ul {
			list-style: none;
			margin: 0;
			padding: var(--space-4) var(--space-5) 0;
			display: flex;
			flex-direction: column;
			gap: var(--space-2);
		}

		.mobile-panel a {
			display: flex;
			align-items: center;
			min-height: 44px;
			color: var(--text-heading);
			text-decoration: none;
			font-weight: 600;
			font-size: 1.0625rem;
		}

		.mobile-contact {
			padding: var(--space-5);
		}
	}
</style>
