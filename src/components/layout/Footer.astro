---
import { Image } from 'astro:assets';
import icon from '../../assets/brand/icon-mark.png';
import ButterflyIcon from '../ui/ButterflyIcon.astro';
import { CONTACT } from '../../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<ButterflyIcon
		static
		class="footer-watermark"
		style="--bfly-top: -6%; --bfly-left: 68%; --bfly-size: 320px; --bfly-opacity: 0.07; color: var(--color-teal-light);"
	/>

	<div class="container footer-statement">
		<div class="footer-brand">
			<Image src={icon} alt="" width={148} height={217} widths={[64, 96]} sizes="40px" class="footer-icon" />
			<p class="footer-name">Bridget Beatty Consulting</p>
		</div>
		<p class="footer-signoff">Grounded in strategy. Built on <em>relationships</em>.</p>
	</div>

	<div class="container footer-utility">
		<div class="footer-contact">
			<a class="footer-email" href={`mailto:${CONTACT.email}`} aria-label={`Email ${CONTACT.name}`}>
				{CONTACT.email}
			</a>
			<p class="footer-location">{CONTACT.location} &middot; {CONTACT.serviceArea}</p>
		</div>

		<a
			class="footer-social"
			href={CONTACT.linkedin}
			target="_blank"
			rel="noopener noreferrer"
			aria-label={`${CONTACT.name} on LinkedIn`}
		>
			<span class="footer-social-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="currentColor">
					<path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45Z" />
				</svg>
			</span>
			<span>LinkedIn</span>
		</a>
	</div>

	<div class="container footer-bottom">
		<p>&copy; {year} Bridget Beatty Consulting. All rights reserved.</p>
		<nav class="footer-legal" aria-label="Legal">
			<a href="/terms-of-service">Terms of Service</a>
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		isolation: isolate;
		background: linear-gradient(165deg, var(--color-navy) 0%, var(--color-navy-light) 100%);
		color: var(--text-on-dark);
		padding-block: var(--space-8) var(--space-5);
		border-top: 1px solid rgba(255, 255, 255, 0.12);
		overflow: hidden;
	}

	/* A quiet echo of the hero's ambient butterflies — a still watermark closing the page. */
	.site-footer :global(.footer-watermark) {
		z-index: -1;
	}

	.footer-statement {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: var(--space-7);
	}

	.footer-brand {
		display: flex;
		align-items: center;
		gap: var(--space-3);
	}

	.footer-icon {
		width: 40px;
		height: auto;
		background: var(--color-white);
		border-radius: 50%;
		padding: 6px;
		transition: transform var(--transition-spring);
	}

	.footer-brand:hover .footer-icon {
		transform: rotate(-8deg) scale(1.08);
	}

	.footer-name {
		font-weight: 700;
		color: var(--color-white);
		font-size: 1.0625rem;
	}

	.footer-signoff {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: clamp(1.375rem, 1.2rem + 1.2vw, 1.875rem);
		line-height: 1.3;
		color: var(--color-white);
		max-width: 26ch;
	}

	.footer-signoff em {
		font-style: italic;
		color: var(--color-teal-light);
	}

	.footer-utility {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-5);
		padding-block: var(--space-6);
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		border-bottom: 1px solid rgba(255, 255, 255, 0.15);
	}

	.footer-contact {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-2) var(--space-3);
	}

	.footer-email {
		color: var(--color-white);
		text-decoration: none;
		font-weight: 600;
		font-size: 1.0625rem;
		transition:
			color var(--transition-base),
			transform var(--transition-base);
		display: inline-block;
	}

	.footer-email:hover {
		color: var(--color-teal-light);
		transform: translateX(3px);
	}

	.footer-location {
		color: var(--text-on-dark-muted);
		font-size: 0.9375rem;
	}

	.footer-social {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3);
		font-weight: 600;
		text-decoration: none;
		color: var(--color-white);
		flex-shrink: 0;
	}

	.footer-social:hover {
		color: var(--color-teal-light);
	}

	.footer-social-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: rgba(141, 235, 229, 0.14);
		color: var(--color-teal-light);
		transition:
			background var(--transition-base),
			color var(--transition-base),
			transform var(--transition-spring);
	}

	.footer-social:hover .footer-social-icon {
		background: var(--color-teal-light);
		color: var(--color-navy);
		transform: scale(1.08);
	}

	.footer-social-icon svg {
		width: 19px;
		height: 19px;
	}

	.footer-bottom {
		padding-top: var(--space-5);
		font-size: 0.8125rem;
		color: var(--text-on-dark-muted);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
	}

	.footer-legal {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}

	.footer-legal a {
		color: var(--text-on-dark-muted);
		text-decoration: none;
		transition: color var(--transition-base);
	}

	.footer-legal a:hover {
		color: var(--color-white);
	}

	@media (max-width: 640px) {
		.footer-utility {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
